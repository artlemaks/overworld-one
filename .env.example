# Overworld One — environment. Copy to .env and adjust. Schema: shared/src/env.ts (EnvSchema).

# docker-compose host port overrides (only needed if 5432/6379 are taken on your machine).
# POSTGRES_HOST_PORT=5442
# REDIS_HOST_PORT=6379

NODE_ENV=development
PORT=8080
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgres://overworld:overworld@localhost:5432/overworld
TICK_HZ=4
LOG_LEVEL=info

# Client (Vite) — WebSocket URL of the authoritative server (OOM-32). Unset → offline P0 mock arena.
# VITE_SERVER_URL=ws://localhost:8080
